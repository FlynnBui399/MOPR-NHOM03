<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvDownloadedTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/poppins_semibold"
            android:maxLines="2"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvDownloadedAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:fontFamily="@font/poppins_regular"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvDownloadedSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/poppins_medium"
            android:textColor="@color/orange_primary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvDownloadedPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="middle"
            android:fontFamily="@font/poppins_regular"
            android:maxLines="1"
            android:textColor="@color/text_muted"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnDeleteDownload"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:background="@drawable/bg_button_outline_orange"
                android:fontFamily="@font/poppins_semibold"
                android:minWidth="96dp"
                android:text="@string/downloads_delete"
                android:textColor="@color/orange_primary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnOpenDownload"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_button_listen_now"
                android:fontFamily="@font/poppins_semibold"
                android:minWidth="96dp"
                android:text="@string/downloads_open"
                android:textColor="@color/white"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
