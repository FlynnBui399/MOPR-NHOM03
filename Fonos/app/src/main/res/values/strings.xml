    <!-- Sample Book Data -->
    <string name="book1_title">Đắc Nhân Tâm</string>
    <string name="book1_author">Dale Carnegie</string>
    <string name="book1_desc">Đắc nhân tâm của Dale Carnegie là quyển sách nổi tiếng nhất, bán chạy nhất và có tầm ảnh hưởng nhất của mọi thời đại. Tác phẩm đã được chuyển ngữ sang hầu hết các thứ tiếng trên thế giới và có mặt ở hàng trăm quốc gia.</string>

    <string name="book2_title">Nhà Giả Kim</string>
    <string name="book2_author">Paulo Coelho</string>
    <string name="book2_desc">Tất cả những trải nghiệm trong chuyến phiêu du theo đuổi vận mệnh của mình đã giúp Santiago nhận ra được ý nghĩa sâu xa nhất của hạnh phúc, hòa hợp với vũ trụ và con người.</string>

    <string name="book3_title">Tuổi Trẻ Đáng Giá Bao Nhiêu</string>
    <string name="book3_author">Rosie Nguyễn</string>
    <string name="book3_desc">Tuổi trẻ đáng giá bao nhiêu là tác phẩm đầu tay của tác giả Rosie Nguyễn, chia sẻ những trải nghiệm và bài học quý giá dành cho người trẻ Việt Nam.</string>

    <string name="book4_title">Sapiens: Lược Sử Loài Người</string>
    <string name="book4_author">Yuval Noah Harari</string>
    <string name="book4_desc">Sapiens khám phá lịch sử loài người từ thời kỳ đồ đá đến thế kỷ 21, đặt ra những câu hỏi lớn về bản chất của loài người chúng ta.</string>

    <string name="book5_title">Tư Duy Nhanh Và Chậm</string>
    <string name="book5_author">Daniel Kahneman</string>
    <string name="book5_desc">Cuốn sách này khám phá hai hệ thống tư duy chi phối cách chúng ta suy nghĩ, đưa ra quyết định và đánh giá mọi thứ trong cuộc sống.</string>

    <string name="book6_title">Atomic Habits</string>
    <string name="book6_author">James Clear</string>
    <string name="book6_desc">Atomic Habits cung cấp một khung thực hành đã được chứng minh để cải thiện mỗi ngày. James Clear tiết lộ các chiến lược thực tế giúp bạn hình thành thói quen tốt.</string>

    <string name="book7_title">Đời Ngắn Đừng Ngủ Dài</string>
    <string name="book7_author">Robin Sharma</string>
    <string name="book7_desc">Robin Sharma chia sẻ những bài học cuộc sống sâu sắc, giúp bạn sống một cuộc đời trọn vẹn và có ý nghĩa hơn mỗi ngày.</string>

    <string name="book8_title">Người Giàu Có Nhất Thành Babylon</string>
    <string name="book8_author">George S. Clason</string>
    <string name="book8_desc">Cuốn sách kinh điển về quản lý tài chính cá nhân, truyền tải những nguyên tắc giàu có vượt thời gian qua những câu chuyện thú vị từ thành Babylon cổ đại.</string>

    <string name="book9_title">7 Thói Quen Hiệu Quả</string>
    <string name="book9_author">Stephen Covey</string>
    <string name="book9_desc">Bảy thói quen của người thành đạt đã trở thành cuốn sách gối đầu giường của hàng triệu người, giúp họ cải thiện bản thân và đạt được thành công.</string>

    <string name="book10_title">Sức Mạnh Tiềm Thức</string>
    <string name="book10_author">Joseph Murphy</string>
    <string name="book10_desc">Khám phá sức mạnh vô hạn của tiềm thức và học cách sử dụng nó để đạt được những điều bạn mong muốn trong cuộc sống.</string>
</resources>