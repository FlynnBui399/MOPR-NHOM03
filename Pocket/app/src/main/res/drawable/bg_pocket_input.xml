<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/pocket_surface" />
            <stroke
                android:width="@dimen/pocket_stroke_focus"
                android:color="@color/pocket_primary" />
            <corners android:radius="@dimen/pocket_radius_md" />
            <padding
                android:bottom="@dimen/pocket_space_md"
                android:left="@dimen/pocket_space_lg"
                android:right="@dimen/pocket_space_lg"
                android:top="@dimen/pocket_space_md" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/pocket_surface" />
            <stroke
                android:width="@dimen/pocket_stroke_hairline"
                android:color="@color/pocket_outline" />
            <corners android:radius="@dimen/pocket_radius_md" />
            <padding
                android:bottom="@dimen/pocket_space_md"
                android:left="@dimen/pocket_space_lg"
                android:right="@dimen/pocket_space_lg"
                android:top="@dimen/pocket_space_md" />
        </shape>
    </item>
</selector>
