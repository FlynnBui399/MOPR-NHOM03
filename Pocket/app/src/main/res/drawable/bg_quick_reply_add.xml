<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="@color/pocket_primary_container" />
            <stroke android:width="1dp" android:color="@color/pocket_primary" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/pocket_surface_variant" />
            <stroke android:width="1dp" android:color="@color/pocket_outline" />
        </shape>
    </item>
</selector>
