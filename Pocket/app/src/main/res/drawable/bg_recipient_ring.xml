<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="oval">
            <solid android:color="@color/pocket_transparent" />
            <stroke android:width="3dp" android:color="@color/pocket_primary" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/pocket_transparent" />
            <stroke android:width="2dp" android:color="@color/pocket_outline" />
        </shape>
    </item>
</selector>
