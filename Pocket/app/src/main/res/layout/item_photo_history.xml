<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pocket_background"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <!-- Top Bar spacing / Sender Row -->
    <LinearLayout
        android:id="@+id/history_sender_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/history_photo_card"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/history_sender_avatar"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/avatar_placeholder"
            app:civ_border_color="@color/pocket_outline"
            app:civ_border_width="1dp" />

        <TextView
            android:id="@+id/history_sender_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:maxLines="1"
            android:textColor="@color/pocket_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Sender Name" />

        <TextView
            android:id="@+id/history_timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:textColor="@color/pocket_text_secondary"
            android:textSize="14sp"
            tools:text="10m ago" />
    </LinearLayout>

    <!-- Photo Frame (Center) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/history_photo_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/pocket_outline"
        app:strokeWidth="1dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintVertical_bias="0.30">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/history_photo_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/history_photo_description"
                android:scaleType="centerCrop" />

            <androidx.media3.ui.PlayerView
                android:id="@+id/history_video_player"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                app:use_controller="false"
                app:resize_mode="zoom" />

            <TextView
                android:id="@+id/tvCaption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_caption_pill"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="2"
                android:ellipsize="end"
                android:visibility="gone"
                tools:text="Sample caption"
                tools:visibility="visible" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Activity Button -->
    <TextView
        android:id="@+id/history_activity_button"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_activity_pill"
        android:gravity="center"
        android:minWidth="150dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:textColor="@color/pocket_text_secondary"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/history_sender_row"
        tools:text="@string/history_no_activity" />

</androidx.constraintlayout.widget.ConstraintLayout>
