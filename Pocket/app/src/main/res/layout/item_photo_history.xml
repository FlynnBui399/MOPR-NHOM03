<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pocket_background"
    android:gravity="top"
    android:orientation="vertical"
    android:paddingStart="6dp"
    android:paddingTop="8dp"
    android:paddingEnd="6dp"
    android:paddingBottom="104dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/history_photo_card"
        android:layout_width="match_parent"
        android:layout_height="360dp"
        app:cardCornerRadius="36dp"
        app:cardElevation="1dp"
        app:strokeColor="@color/pocket_outline"
        app:strokeWidth="1dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/history_photo_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/history_photo_description"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/history_caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_history_caption_chip"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="2"
                android:maxWidth="320dp"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/history_sender_avatar"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/avatar_placeholder"
            app:civ_border_color="@color/pocket_outline"
            app:civ_border_width="1dp" />

        <TextView
            android:id="@+id/history_sender_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:maxLines="1"
            android:textColor="@color/pocket_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/history_timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:textColor="@color/pocket_text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <Space
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/history_activity_button"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="64dp"
        android:background="@drawable/bg_activity_pill"
        android:gravity="center"
        android:minWidth="150dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:text="@string/history_no_activity"
        android:textColor="@color/pocket_text_secondary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/history_reply_row"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="64dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/bg_reply_input"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <EditText
            android:id="@+id/history_reply_input"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/pocket_transparent"
            android:hint="@string/history_reply_hint"
            android:importantForAutofill="no"
            android:imeOptions="actionSend"
            android:inputType="textCapSentences"
            android:maxLines="1"
            android:padding="0dp"
            android:singleLine="true"
            android:textColor="@color/pocket_text_primary"
            android:textColorHint="@color/pocket_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/history_reaction_hearts"
            android:layout_width="38dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="@string/reaction_hearts"
            android:textSize="21sp" />

        <TextView
            android:id="@+id/history_reaction_shock"
            android:layout_width="38dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="@string/reaction_shock"
            android:textSize="21sp" />

        <TextView
            android:id="@+id/history_reaction_fire"
            android:layout_width="38dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="@string/reaction_fire"
            android:textSize="21sp" />

        <TextView
            android:id="@+id/history_reaction_more"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/bg_quick_reply_add"
            android:gravity="center"
            android:contentDescription="@string/history_more_reactions"
            android:text="@string/reaction_more"
            android:textColor="@color/pocket_text_primary"
            android:textSize="24sp" />
    </LinearLayout>
</LinearLayout>
