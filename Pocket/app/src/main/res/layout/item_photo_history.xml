<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pocket_background"
    android:orientation="vertical"
    android:paddingStart="6dp"
    android:paddingTop="14dp"
    android:paddingEnd="6dp"
    android:paddingBottom="108dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <View
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.example.pocket.ui.PocketButton
            android:id="@+id/history_recipient_pill"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:minHeight="0dp"
            android:minWidth="132dp"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:text="@string/history_filter_everyone"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:pocketVariant="secondary" />

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/history_profile_avatar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:contentDescription="@string/nav_profile"
            android:src="@drawable/avatar_placeholder"
            app:civ_border_color="@color/pocket_primary"
            app:civ_border_width="2dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/history_photo_card"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            app:cardCornerRadius="34dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/pocket_outline"
            app:strokeWidth="1dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/history_photo_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/history_photo_description"
                    android:scaleType="centerCrop" />

                <TextView
                    android:id="@+id/history_caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/bg_history_caption_chip"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="2"
                    android:maxWidth="320dp"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.example.pocket.ui.AvatarView
                android:id="@+id/history_sender_avatar"
                android:layout_width="34dp"
                android:layout_height="34dp"
                app:avatarSize="34dp" />

            <TextView
                android:id="@+id/history_sender_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:maxLines="1"
                android:textColor="@color/pocket_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/history_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:textColor="@color/pocket_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/history_reply_row"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginStart="6dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_reply_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="8dp">

            <EditText
                android:id="@+id/history_reply_input"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/pocket_transparent"
                android:hint="@string/history_reply_hint"
                android:importantForAutofill="no"
                android:imeOptions="actionSend"
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:padding="0dp"
                android:singleLine="true"
                android:textColor="@color/pocket_text_primary"
                android:textColorHint="@color/pocket_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/history_reaction_hotdog"
                android:layout_width="38dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="@string/reaction_hotdog"
                android:textSize="21sp" />

            <TextView
                android:id="@+id/history_reaction_heart_eyes"
                android:layout_width="38dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="@string/reaction_heart_eyes"
                android:textSize="21sp" />

            <TextView
                android:id="@+id/history_reaction_hearts"
                android:layout_width="38dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="@string/reaction_hearts"
                android:textSize="21sp" />

            <TextView
                android:id="@+id/history_reaction_smile"
                android:layout_width="38dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="@string/reaction_smile"
                android:textSize="21sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
