<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:padding="16dp">

    <!-- Title / Header Label -->
    <TextView
        android:id="@+id/tv_preview_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Review your Pocket"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Video Preview Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/video_preview_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/black"
        app:cardCornerRadius="36dp"
        app:cardElevation="2dp"
        app:strokeColor="@color/pocket_outline"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/tv_preview_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="1:1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.media3.ui.PlayerView
                android:id="@+id/player_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:use_controller="false"
                app:resize_mode="zoom" />

            <LinearLayout
                android:id="@+id/caption_panel"
                android:layout_width="228dp"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginStart="28dp"
                android:layout_marginEnd="28dp"
                android:layout_marginBottom="18dp"
                android:gravity="center"
                android:orientation="vertical"
                android:background="@drawable/bg_capture_caption_chip"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/caption_input_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundMode="none"
                    app:hintAnimationEnabled="false"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/caption_input"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="@color/pocket_transparent"
                        android:gravity="center"
                        android:hint="Add a caption…"
                        android:inputType="textCapSentences"
                        android:maxLength="100"
                        android:maxLines="1"
                        android:textColor="@color/white"
                        android:textColorHint="@color/pocket_white_60"
                        android:singleLine="true"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Controls Container -->
    <LinearLayout
        android:id="@+id/preview_controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Retake Button -->
        <com.example.pocket.ui.PocketButton
            android:id="@+id/btn_retake"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Retake"
            app:pocketVariant="outline"
            app:icon="@drawable/ic_close"
            app:iconGravity="textStart" />

        <!-- Send Button -->
        <com.example.pocket.ui.PocketButton
            android:id="@+id/btn_send"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Send"
            app:pocketVariant="primary"
            app:icon="@drawable/ic_send_diagonal"
            app:iconGravity="textStart" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
