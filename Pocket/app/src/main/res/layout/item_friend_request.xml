<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="220dp"
    android:layout_height="match_parent"
    android:layout_marginEnd="10dp"
    android:background="@drawable/bg_glass_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/request_item_avatar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/avatar_placeholder" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/request_item_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            tools:text="Pocket User" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <com.example.pocket.ui.PocketButton
                android:id="@+id/request_item_accept_button"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/friend_accept"
                android:textSize="12sp"
                app:cornerRadius="17dp"
                app:pocketVariant="primary" />

            <com.example.pocket.ui.PocketButton
                android:id="@+id/request_item_decline_button"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="6dp"
                android:text="@string/friend_decline"
                android:textSize="12sp"
                app:cornerRadius="17dp"
                app:pocketVariant="outline" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
