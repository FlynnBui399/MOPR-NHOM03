<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:clipToPadding="false"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingBottom="110dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/profile_avatar"
            android:layout_width="104dp"
            android:layout_height="104dp"
            android:background="@drawable/bg_avatar_border"
            android:padding="3dp"
            android:src="@drawable/avatar_placeholder" />

        <TextView
            android:id="@+id/profile_display_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            tools:text="Pocket User" />

        <TextView
            android:id="@+id/profile_phone_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#99FFFFFF"
            android:textSize="14sp"
            tools:text="+84901234567" />

        <com.example.pocket.ui.PocketButton
            android:id="@+id/profile_edit_name_button"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:stateListAnimator="@animator/scale_press"
            android:text="Đổi tên hiển thị"
            app:cornerRadius="24dp"
            app:pocketVariant="secondary" />

        <EditText
            android:id="@+id/profile_name_edit_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_settings_card"
            android:hint="Nhập tên mới..."
            android:inputType="textPersonName"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#99FFFFFF"
            android:textSize="16sp"
            android:visibility="gone" />

        <com.example.pocket.ui.PocketButton
            android:id="@+id/profile_save_name_button"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:stateListAnimator="@animator/scale_press"
            android:text="Lưu"
            android:visibility="gone"
            app:cornerRadius="24dp"
            app:pocketVariant="primary" />

        <com.example.pocket.ui.PocketButton
            android:id="@+id/profile_change_avatar_button"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:stateListAnimator="@animator/scale_press"
            android:text="@string/profile_change_avatar"
            app:cornerRadius="24dp"
            app:pocketVariant="secondary" />

        <LinearLayout
            android:id="@+id/profile_notification_row"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_settings_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/profile_notifications"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <Switch
                android:id="@+id/profile_notification_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/profile_privacy_row"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_settings_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/profile_privacy"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/profile_logout_row"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_settings_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/profile_logout"
                android:textColor="#FF4444"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
