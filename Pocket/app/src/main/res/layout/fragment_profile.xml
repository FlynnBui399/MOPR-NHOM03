<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pocket_background"
    android:clipToPadding="false"
    android:padding="@dimen/pocket_space_xl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingBottom="120dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/profile_avatar"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:background="@drawable/bg_avatar_gradient_ring"
            android:padding="3dp"
            android:src="@drawable/avatar_placeholder" />

        <TextView
            android:id="@+id/profile_display_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pocket_space_lg"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/pocket_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            tools:text="Pocket User" />

        <TextView
            android:id="@+id/profile_phone_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pocket_space_xs"
            android:textColor="@color/pocket_text_secondary"
            android:textSize="@dimen/pocket_text_body"
            tools:text="+84901234567" />

        <LinearLayout
            android:id="@+id/profile_stats_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pocket_space_xl"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="78dp"
                android:layout_marginEnd="@dimen/pocket_space_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_profile_stat_card"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/profile_photos_sent_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_stat_zero"
                    android:textColor="@color/pocket_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    style="@style/TextAppearance.Pocket.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/pocket_space_xs"
                    android:text="@string/profile_stats_photos_sent"
                    android:textColor="@color/pocket_nav_icon_unselected" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="78dp"
                android:layout_marginStart="@dimen/pocket_space_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_profile_stat_card"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/profile_friends_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_stat_zero"
                    android:textColor="@color/pocket_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    style="@style/TextAppearance.Pocket.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/pocket_space_xs"
                    android:text="@string/profile_stats_friends"
                    android:textColor="@color/pocket_nav_icon_unselected" />
            </LinearLayout>
        </LinearLayout>

        <com.example.pocket.ui.PocketButton
            android:id="@+id/profile_edit_name_button"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/pocket_button_height"
            android:layout_marginTop="@dimen/pocket_space_lg"
            android:stateListAnimator="@animator/scale_press"
            android:text="@string/profile_edit_name"
            app:cornerRadius="@dimen/pocket_radius_md"
            app:pocketVariant="secondary" />

        <EditText
            android:id="@+id/profile_name_edit_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pocket_space_sm"
            android:background="@drawable/bg_pocket_input"
            android:hint="@string/profile_name_hint"
            android:inputType="textPersonName"
            android:padding="@dimen/pocket_space_md"
            android:textColor="@color/pocket_text_primary"
            android:textColorHint="@color/pocket_text_secondary"
            android:textSize="16sp"
            android:visibility="gone" />

        <com.example.pocket.ui.PocketButton
            android:id="@+id/profile_save_name_button"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/pocket_button_height"
            android:layout_marginTop="@dimen/pocket_space_sm"
            android:stateListAnimator="@animator/scale_press"
            android:text="@string/profile_save_name"
            android:visibility="gone"
            app:cornerRadius="@dimen/pocket_radius_md"
            app:pocketVariant="primary" />

        <com.example.pocket.ui.PocketButton
            android:id="@+id/profile_change_avatar_button"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/pocket_button_height"
            android:layout_marginTop="@dimen/pocket_space_md"
            android:stateListAnimator="@animator/scale_press"
            android:text="@string/profile_change_avatar"
            app:cornerRadius="@dimen/pocket_radius_md"
            app:pocketVariant="secondary" />

        <LinearLayout
            android:id="@+id/profile_settings_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pocket_space_2xl"
            android:background="@drawable/bg_settings_card"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/profile_notification_row"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/pocket_space_lg"
                android:paddingEnd="@dimen/pocket_space_lg">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/profile_notifications"
                    android:textColor="@color/pocket_text_primary"
                    android:textSize="16sp" />

                <Switch
                    android:id="@+id/profile_notification_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/pocket_stroke_hairline"
                android:background="@drawable/divider_pocket" />

            <LinearLayout
                android:id="@+id/profile_theme_row"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/pocket_space_lg"
                android:paddingEnd="@dimen/pocket_space_lg">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/profile_theme"
                    android:textColor="@color/pocket_text_primary"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/profile_theme_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/pocket_space_md"
                    android:textColor="@color/pocket_text_secondary"
                    android:textSize="16sp"
                    tools:text="Light" />

                <Switch
                    android:id="@+id/profile_theme_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:focusable="false" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/pocket_stroke_hairline"
                android:background="@drawable/divider_pocket" />

            <LinearLayout
                android:id="@+id/profile_language_row"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/pocket_space_lg"
                android:paddingEnd="@dimen/pocket_space_lg">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/profile_language"
                    android:textColor="@color/pocket_text_primary"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/profile_language_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/pocket_text_secondary"
                    android:textSize="16sp"
                    tools:text="English" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/pocket_stroke_hairline"
                android:background="@drawable/divider_pocket" />

            <LinearLayout
                android:id="@+id/profile_privacy_row"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/pocket_space_lg"
                android:paddingEnd="@dimen/pocket_space_lg">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_privacy"
                    android:textColor="@color/pocket_text_primary"
                    android:textSize="16sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/pocket_stroke_hairline"
                android:background="@drawable/divider_pocket" />

            <LinearLayout
                android:id="@+id/profile_logout_row"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/pocket_space_lg"
                android:paddingEnd="@dimen/pocket_space_lg">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_logout"
                    android:textColor="@color/pocket_danger"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
