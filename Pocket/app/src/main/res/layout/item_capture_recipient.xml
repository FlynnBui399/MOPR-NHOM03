<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="68dp"
    android:layout_height="76dp"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="5dp"
    android:paddingEnd="5dp">

    <FrameLayout
        android:id="@+id/capture_recipient_ring"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="@drawable/bg_recipient_ring"
        android:padding="2dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/capture_recipient_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/avatar_placeholder"
            app:civ_circle_background_color="@color/pocket_surface_variant" />

        <TextView
            android:id="@+id/capture_recipient_initials"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_pocket_avatar_placeholder"
            android:gravity="center"
            android:textColor="@color/pocket_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </FrameLayout>

    <TextView
        android:id="@+id/capture_recipient_name"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="@color/selector_recipient_text"
        android:textSize="11sp"
        android:textStyle="bold" />
</LinearLayout>
