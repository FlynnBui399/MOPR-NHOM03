<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pocket_background"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:fitsSystemWindows="false"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/pocket_transparent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center_vertical"
        android:minHeight="64dp"
        android:orientation="horizontal"
        android:paddingStart="@dimen/pocket_space_lg"
        android:paddingTop="0dp"
        android:paddingEnd="@dimen/pocket_space_lg"
        android:paddingBottom="@dimen/pocket_space_sm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/top_bar_avatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_avatar_border"
            android:padding="2dp"
            android:src="@drawable/avatar_placeholder" />

        <LinearLayout
            android:id="@+id/top_bar_filter_pill"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:background="@drawable/bg_filter_pill"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/top_bar_filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="@string/top_bar_filter_all_friends"
                android:textColor="@color/pocket_text_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <ImageButton
                android:id="@+id/top_bar_chat_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_circle_dark"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:padding="9dp"
                android:src="@drawable/ic_message"
                android:stateListAnimator="@animator/scale_press"
                app:tint="@color/pocket_text_primary" />

            <View
                android:id="@+id/top_bar_chat_badge"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="3dp"
                android:layout_marginEnd="3dp"
                android:background="@drawable/bg_unread_badge"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/main_fragment_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/main_bottom_nav_pill"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar" />

    <LinearLayout
        android:id="@+id/main_bottom_nav_pill"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_bottom_nav_pill"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="8dp"
        android:gravity="center"
        android:minHeight="84dp"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingTop="10dp"
        android:paddingEnd="24dp"
        android:paddingBottom="10dp"
        android:translationY="-20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/nav_feed_button"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_nav_side_button"
            android:contentDescription="@string/nav_feed"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:scaleType="center"
            android:src="@drawable/ic_nav_feed"
            android:stateListAnimator="@animator/scale_nav_press"
            app:tint="@color/selector_nav_icon_tint" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/nav_camera_button"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_camera_fab"
            android:contentDescription="@string/nav_camera"
            android:elevation="12dp"
            android:outlineAmbientShadowColor="@color/pocket_fab_shadow"
            android:outlineSpotShadowColor="@color/pocket_fab_shadow"
            android:padding="18dp"
            android:scaleType="center"
            android:src="@drawable/ic_nav_camera"
            android:stateListAnimator="@animator/scale_nav_press"
            android:translationY="-14dp"
            app:tint="@color/pocket_text_primary" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/nav_friends_button"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_nav_side_button"
            android:contentDescription="@string/nav_friends"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:scaleType="center"
            android:src="@drawable/ic_nav_friends"
            android:stateListAnimator="@animator/scale_nav_press"
            app:tint="@color/selector_nav_icon_tint" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
