<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".MainActivity">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/main_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/main_bottom_nav_pill"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_bottom_nav_pill"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp">

        <ImageButton
            android:id="@+id/nav_feed_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_feed"
            android:padding="12dp"
            android:scaleType="center"
            android:src="@drawable/ic_nav_feed"
            android:stateListAnimator="@animator/scale_press"
            app:tint="@color/selector_nav_icon_tint" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/nav_camera_button"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_camera_fab"
            android:contentDescription="@string/nav_camera"
            android:elevation="4dp"
            android:padding="17dp"
            android:scaleType="center"
            android:src="@drawable/ic_nav_camera"
            android:stateListAnimator="@animator/scale_press"
            android:translationY="-8dp"
            app:tint="#FFFFFF" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/nav_friends_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_friends"
            android:padding="12dp"
            android:scaleType="center"
            android:src="@drawable/ic_nav_friends"
            android:stateListAnimator="@animator/scale_press"
            app:tint="@color/selector_nav_icon_tint" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/nav_profile_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_profile"
            android:padding="12dp"
            android:scaleType="center"
            android:src="@drawable/ic_nav_profile"
            android:stateListAnimator="@animator/scale_press"
            app:tint="@color/selector_nav_icon_tint" />
    </LinearLayout>
</FrameLayout>
