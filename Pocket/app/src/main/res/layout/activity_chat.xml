<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/chat_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_pocket_screen"
    tools:context=".ChatActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/chat_toolbar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@color/pocket_surface"
        android:elevation="0dp"
        android:minHeight="64dp"
        android:paddingStart="@dimen/pocket_space_lg"
        android:paddingEnd="@dimen/pocket_space_lg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.example.pocket.ui.AvatarView
            android:id="@+id/chat_other_avatar"
            android:layout_width="@dimen/pocket_avatar_md"
            android:layout_height="@dimen/pocket_avatar_md"
            android:layout_gravity="center_vertical"
            android:contentDescription="@string/chat_avatar_description"
            app:avatarText="Pocket User" />

        <TextView
            android:id="@+id/chat_other_name"
            style="@style/TextAppearance.Pocket.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="@dimen/pocket_space_md"
            android:ellipsize="end"
            android:maxLines="1"
            tools:text="Pocket User" />
    </com.google.android.material.appbar.MaterialToolbar>

    <View
        android:id="@+id/chat_toolbar_divider"
        android:layout_width="0dp"
        android:layout_height="@dimen/pocket_stroke_hairline"
        android:background="@drawable/divider_pocket"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chat_toolbar" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chat_messages_recycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="@dimen/pocket_space_lg"
        android:paddingTop="@dimen/pocket_space_lg"
        android:paddingEnd="@dimen/pocket_space_lg"
        android:paddingBottom="@dimen/pocket_space_lg"
        app:layout_constraintBottom_toTopOf="@id/chat_composer_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chat_toolbar_divider"
        tools:itemCount="8"
        tools:listitem="@layout/item_chat_message" />

    <LinearLayout
        android:id="@+id/chat_composer_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chat_composer"
        android:orientation="vertical"
        android:paddingStart="@dimen/pocket_space_lg"
        android:paddingTop="@dimen/pocket_space_sm"
        android:paddingEnd="@dimen/pocket_space_lg"
        android:paddingBottom="@dimen/pocket_space_lg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <HorizontalScrollView
            android:id="@+id/chat_quick_reply_scroll"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/chat_quick_reply_bar"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/quick_reply_smile"
                    style="@style/TextAppearance.Pocket.Title"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="&#128522;" />

                <TextView
                    android:id="@+id/quick_reply_laugh"
                    style="@style/TextAppearance.Pocket.Title"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="&#128514;" />

                <TextView
                    android:id="@+id/quick_reply_thumb"
                    style="@style/TextAppearance.Pocket.Title"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="&#128077;" />

                <TextView
                    android:id="@+id/quick_reply_heart"
                    style="@style/TextAppearance.Pocket.Title"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="&#10084;&#65039;" />

                <TextView
                    android:id="@+id/quick_reply_surprise"
                    style="@style/TextAppearance.Pocket.Title"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="&#128558;" />
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/chat_input_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="bottom"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/chat_message_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_pocket_input"
                android:hint="@string/chat_message_hint"
                android:imeOptions="actionSend"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="4"
                android:minHeight="@dimen/pocket_input_height"
                android:minLines="1"
                android:paddingStart="@dimen/pocket_space_lg"
                android:paddingEnd="@dimen/pocket_space_lg"
                android:textColor="@color/pocket_text_primary"
                android:textColorHint="@color/pocket_placeholder"
                android:textSize="@dimen/pocket_text_body" />

            <com.example.pocket.ui.PocketButton
                android:id="@+id/chat_send_button"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/pocket_input_height"
                android:layout_marginStart="@dimen/pocket_space_sm"
                android:text="@string/chat_send"
                app:pocketVariant="primary" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
