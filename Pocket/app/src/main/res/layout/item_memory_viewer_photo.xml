<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="14dp"
    android:paddingEnd="14dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardCornerRadius="38dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/memory_viewer_photo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/history_photo_description"
            android:scaleType="centerCrop" />

        <androidx.media3.ui.PlayerView
            android:id="@+id/memory_viewer_video"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:use_controller="false"
            app:resize_mode="zoom"
            android:visibility="gone" />

        <TextView
            android:id="@+id/memory_viewer_caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_caption_pill"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="2"
            android:ellipsize="end"
            android:visibility="gone" />
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
