<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/otp_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_pocket_screen"
    android:padding="@dimen/pocket_space_xl"
    tools:context=".OtpActivity">

    <LinearLayout
        android:id="@+id/otp_content"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/otp_title"
            style="@style/TextAppearance.Pocket.Headline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/otp_title" />

        <TextView
            android:id="@+id/otp_subtitle"
            style="@style/TextAppearance.Pocket.BodySmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pocket_space_sm"
            android:text="@string/otp_subtitle" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/phone_input_layout"
            style="@style/Widget.Pocket.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pocket_space_xl"
            android:hint="@string/otp_phone_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/phone_input"
                style="@style/TextAppearance.Pocket.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionSend"
                android:inputType="phone"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.example.pocket.ui.PocketButton
            android:id="@+id/send_otp_button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/pocket_button_height"
            android:layout_marginTop="@dimen/pocket_space_md"
            android:text="@string/otp_send"
            app:pocketVariant="primary" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/otp_input_layout"
            style="@style/Widget.Pocket.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pocket_space_xl"
            android:hint="@string/otp_code_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/otp_input"
                style="@style/TextAppearance.Pocket.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionDone"
                android:inputType="number"
                android:maxLength="6"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.example.pocket.ui.PocketButton
            android:id="@+id/verify_otp_button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/pocket_button_height"
            android:layout_marginTop="@dimen/pocket_space_md"
            android:text="@string/otp_verify"
            app:pocketVariant="secondary" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
