<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/add_friend_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pocket_background"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    tools:context=".AddFriendActivity">

    <ImageButton
        android:id="@+id/add_friend_back_button"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="24dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/pocket_text_primary" />

    <TextView
        android:id="@+id/add_friend_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="@string/add_friend_title"
        android:textColor="@color/pocket_text_primary"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="@id/add_friend_back_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/add_friend_back_button" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/add_friend_phone_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="44dp"
        android:hint="@string/add_friend_phone_hint"
        app:boxBackgroundColor="@color/pocket_transparent"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusBottomEnd="@dimen/pocket_radius_md"
        app:boxCornerRadiusBottomStart="@dimen/pocket_radius_md"
        app:boxCornerRadiusTopEnd="@dimen/pocket_radius_md"
        app:boxCornerRadiusTopStart="@dimen/pocket_radius_md"
        app:boxStrokeColor="@color/selector_pocket_input_stroke"
        app:hintTextColor="@color/pocket_text_muted"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/add_friend_back_button">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/add_friend_phone_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="phone"
            android:maxLines="1"
            android:textColor="@color/pocket_text_primary"
            android:textColorHint="@color/pocket_text_muted"
            android:textSize="16sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.example.pocket.ui.PocketButton
        android:id="@+id/add_friend_search_button"
        android:layout_width="0dp"
        android:layout_height="@dimen/pocket_button_height"
        android:layout_marginTop="16dp"
        android:stateListAnimator="@animator/scale_press"
        android:text="@string/add_friend_search"
        app:cornerRadius="@dimen/pocket_radius_md"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/add_friend_phone_layout"
        app:pocketVariant="primary" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/add_friend_result_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/pocket_surface"
        app:cardCornerRadius="@dimen/pocket_radius_lg"
        app:cardElevation="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/add_friend_search_button"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/add_friend_result_avatar"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/avatar_placeholder" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/add_friend_result_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/pocket_text_primary"
                    android:textSize="16sp"
                    tools:text="Pocket User" />

                <TextView
                    android:id="@+id/add_friend_result_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/pocket_text_secondary"
                    android:textSize="12sp"
                    tools:text="+84901234567" />
            </LinearLayout>

            <com.example.pocket.ui.PocketButton
                android:id="@+id/add_friend_send_request_button"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/add_friend_send_request"
                android:textSize="13sp"
                app:cornerRadius="@dimen/pocket_radius_md"
                app:pocketVariant="primary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>
