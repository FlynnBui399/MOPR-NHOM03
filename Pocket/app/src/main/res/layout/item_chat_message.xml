<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="@dimen/pocket_space_xs"
    android:paddingBottom="@dimen/pocket_space_xs">

    <TextView
        android:id="@+id/chat_received_bubble"
        style="@style/TextAppearance.Pocket.Body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chat_bubble_received_dark"
        android:maxWidth="280dp"
        android:textColor="#FFFFFF"
        app:layout_constraintEnd_toStartOf="@id/chat_sent_bubble"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_default="wrap"
        tools:text="Received message" />

    <TextView
        android:id="@+id/chat_sent_bubble"
        style="@style/TextAppearance.Pocket.Body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chat_bubble_sent"
        android:maxWidth="280dp"
        android:textColor="@color/pocket_on_primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1"
        app:layout_constraintStart_toEndOf="@id/chat_received_bubble"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_default="wrap"
        tools:text="Sent message" />
</androidx.constraintlayout.widget.ConstraintLayout>
