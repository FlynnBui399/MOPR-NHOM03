<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/camera_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:fitsSystemWindows="false"
    tools:context=".CameraActivity">

    <androidx.camera.view.PreviewView
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/camera_preview"
        app:scaleType="fillCenter" />

    <ImageView
        android:id="@+id/captured_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:contentDescription="@string/camera_photo_preview"
        android:scaleType="centerCrop"
        android:visibility="gone"
        tools:visibility="visible" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/camera_top_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingStart="20dp"
        android:paddingTop="32dp"
        android:paddingEnd="20dp">

        <ImageButton
            android:id="@+id/camera_close_button"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_button_overlay"
            android:contentDescription="@string/camera_retake"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:src="@drawable/ic_close"
            android:stateListAnimator="@animator/scale_press"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/pocket_text_primary" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/camera_bottom_panel"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_scrim"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/caption_input_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/camera_caption_hint"
            android:visibility="gone"
            app:boxBackgroundColor="@color/pocket_transparent"
            app:boxBackgroundMode="none"
            app:hintTextColor="@color/pocket_text_secondary"
            app:layout_constraintBottom_toTopOf="@id/suggest_caption_button"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:visibility="visible">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/caption_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/pocket_transparent"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="3"
                android:textColor="@color/pocket_text_primary"
                android:textColorHint="@color/pocket_text_secondary"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.example.pocket.ui.PocketButton
            android:id="@+id/suggest_caption_button"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginBottom="14dp"
            android:stateListAnimator="@animator/scale_press"
            android:text="@string/camera_suggest_caption"
            android:textSize="14sp"
            android:visibility="gone"
            app:cornerRadius="20dp"
            app:layout_constraintBottom_toTopOf="@id/capture_cluster"
            app:layout_constraintEnd_toEndOf="parent"
            app:pocketVariant="secondary"
            tools:visibility="visible" />

        <com.example.pocket.ui.PocketButton
            android:id="@+id/retake_button"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_button_overlay"
            android:padding="10dp"
            android:stateListAnimator="@animator/scale_press"
            android:text=""
            android:textSize="0sp"
            android:visibility="gone"
            app:icon="@drawable/ic_retake"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="24dp"
            app:layout_constraintBottom_toBottomOf="@id/capture_cluster"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/capture_cluster"
            app:pocketVariant="ghost"
            tools:visibility="visible" />

        <com.example.pocket.ui.PocketButton
            android:id="@+id/flash_button"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="26dp"
            android:background="@drawable/bg_icon_button_overlay"
            android:padding="10dp"
            android:stateListAnimator="@animator/scale_press"
            android:text=""
            android:textSize="0sp"
            app:icon="@drawable/ic_flash_auto"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="24dp"
            app:layout_constraintBottom_toBottomOf="@id/capture_cluster"
            app:layout_constraintEnd_toStartOf="@id/capture_cluster"
            app:layout_constraintTop_toTopOf="@id/capture_cluster"
            app:pocketVariant="ghost" />

        <FrameLayout
            android:id="@+id/capture_cluster"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:background="@drawable/bg_shutter_ring"
            android:clipChildren="false"
            android:clipToPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <View
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_shutter_button" />

            <com.example.pocket.ui.PocketButton
                android:id="@+id/capture_button"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:background="@color/pocket_transparent"
                android:minHeight="0dp"
                android:padding="0dp"
                android:stateListAnimator="@animator/scale_press"
                android:text=""
                android:textSize="0sp"
                app:pocketVariant="ghost" />
        </FrameLayout>

        <com.example.pocket.ui.PocketButton
            android:id="@+id/flip_button"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="26dp"
            android:background="@drawable/bg_icon_button_overlay"
            android:padding="10dp"
            android:stateListAnimator="@animator/scale_press"
            android:text=""
            android:textSize="0sp"
            app:icon="@drawable/ic_flip_camera"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="24dp"
            app:layout_constraintBottom_toBottomOf="@id/capture_cluster"
            app:layout_constraintStart_toEndOf="@id/capture_cluster"
            app:layout_constraintTop_toTopOf="@id/capture_cluster"
            app:pocketVariant="ghost" />

        <com.example.pocket.ui.PocketButton
            android:id="@+id/send_photo_button"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_camera_fab"
            android:padding="16dp"
            android:stateListAnimator="@animator/scale_press"
            android:text=""
            android:textSize="0sp"
            android:visibility="gone"
            app:icon="@drawable/ic_send"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="24dp"
            app:layout_constraintBottom_toBottomOf="@id/capture_cluster"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/capture_cluster"
            app:pocketVariant="primary"
            tools:visibility="visible" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
