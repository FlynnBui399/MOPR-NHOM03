<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pocket_background"
    android:paddingStart="8dp"
    android:paddingTop="14dp"
    android:paddingEnd="8dp"
    android:paddingBottom="0dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/camera_preview_card"
        android:layout_width="0dp"
        android:layout_height="360dp"
        android:layout_marginTop="10dp"
        app:cardBackgroundColor="@color/black"
        app:cardCornerRadius="36dp"
        app:cardElevation="2dp"
        app:strokeColor="@color/pocket_outline"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.camera.view.PreviewView
                android:id="@+id/camera_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/camera_preview"
                app:scaleType="fillCenter" />

            <ImageView
                android:id="@+id/captured_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/camera_photo_preview"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <com.example.pocket.ui.PocketButton
                android:id="@+id/save_photo_button"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="top|end"
                android:layout_margin="14dp"
                android:contentDescription="@string/camera_save_photo"
                android:minHeight="0dp"
                android:padding="13dp"
                android:text=""
                android:visibility="gone"
                app:cornerRadius="25dp"
                app:icon="@drawable/ic_download"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="24dp"
                app:pocketVariant="secondary" />

            <LinearLayout
                android:id="@+id/caption_panel"
                android:layout_width="228dp"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginStart="28dp"
                android:layout_marginEnd="28dp"
                android:layout_marginBottom="18dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/caption_input_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_capture_caption_chip"
                    android:minWidth="180dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    app:boxBackgroundMode="none"
                    app:hintAnimationEnabled="false"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/caption_input"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="@color/pocket_transparent"
                        android:gravity="center"
                        android:hint="@string/camera_add_message"
                        android:inputType="textCapSentences"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:minWidth="148dp"
                        android:padding="0dp"
                        android:textColor="@color/white"
                        android:textColorHint="@color/pocket_white_60"
                        android:singleLine="true"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Mode Toggle Pill -->
            <LinearLayout
                android:id="@+id/modeToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_toggle_pill"
                android:orientation="horizontal"
                android:padding="4dp"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/btnModePhoto"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_toggle_circle"
                    android:src="@drawable/ic_nav_camera"
                    android:contentDescription="@string/nav_home"
                    app:tint="#00E5FF"
                    android:padding="6dp"
                    android:scaleType="fitCenter" />

                <ImageButton
                    android:id="@+id/btnModeVideo"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@null"
                    android:src="@drawable/ic_videocam"
                    android:contentDescription="@string/camera_suggest_caption"
                    app:tint="@color/pocket_text_muted"
                    android:padding="6dp"
                    android:scaleType="fitCenter"
                    android:layout_marginStart="4dp" />
            </LinearLayout>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>



    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/camera_controls"
        android:layout_width="0dp"
        android:layout_height="112dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/camera_preview_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.example.pocket.ui.PocketButton
            android:id="@+id/gallery_button"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:contentDescription="@string/camera_gallery"
            android:minHeight="0dp"
            android:padding="14dp"
            android:text=""
            app:cornerRadius="34dp"
            app:icon="@drawable/ic_gallery"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="36dp"
            app:layout_constraintBottom_toBottomOf="@id/capture_cluster"
            app:layout_constraintEnd_toStartOf="@id/capture_cluster"
            android:layout_marginEnd="22dp"
            app:layout_constraintTop_toTopOf="@id/capture_cluster"
            app:pocketVariant="ghost" />

        <com.example.pocket.ui.PocketButton
            android:id="@+id/retake_button"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:contentDescription="@string/camera_discard_photo"
            android:minHeight="0dp"
            android:padding="16dp"
            android:text=""
            android:visibility="gone"
            app:cornerRadius="32dp"
            app:icon="@drawable/ic_close"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="30dp"
            app:layout_constraintBottom_toBottomOf="@id/capture_cluster"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/capture_cluster"
            app:pocketVariant="ghost" />

        <FrameLayout
            android:id="@+id/capture_cluster"
            android:layout_width="94dp"
            android:layout_height="94dp"
            android:background="@drawable/bg_shutter_ring_light"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ProgressBar
                android:id="@+id/video_record_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/circular_progress_bar"
                android:visibility="gone" />

            <View
                android:id="@+id/capture_button_surface"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_shutter_button" />

            <com.example.pocket.ui.PocketButton
                android:id="@+id/capture_button"
                android:layout_width="94dp"
                android:layout_height="94dp"
                android:background="@color/pocket_transparent"
                android:contentDescription="@string/camera_capture"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text=""
                app:pocketVariant="ghost" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/send_photo_button"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_capture_send_button"
                android:contentDescription="@string/camera_send"
                android:padding="16dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_send_diagonal"
                android:visibility="gone"
                app:tint="@color/pocket_text_primary" />

            <com.example.pocket.ui.RecordingBorderView
                android:id="@+id/recording_border_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="0dp"
                android:clickable="false"
                android:focusable="false"
                android:visibility="gone" />
        </FrameLayout>

        <com.example.pocket.ui.PocketButton
            android:id="@+id/flip_button"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:layout_marginStart="22dp"
            android:contentDescription="@string/camera_flip"
            android:minHeight="0dp"
            android:padding="14dp"
            android:text=""
            app:cornerRadius="34dp"
            app:icon="@drawable/ic_flip_camera"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="36dp"
            app:layout_constraintBottom_toBottomOf="@id/capture_cluster"
            app:layout_constraintStart_toEndOf="@id/capture_cluster"
            app:layout_constraintTop_toTopOf="@id/capture_cluster"
            app:pocketVariant="ghost" />

        <com.example.pocket.ui.PocketButton
            android:id="@+id/suggest_caption_button"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:contentDescription="@string/camera_suggest_caption"
            android:minHeight="0dp"
            android:padding="12dp"
            android:text="AI"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:cornerRadius="30dp"
            app:layout_constraintBottom_toBottomOf="@id/capture_cluster"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/capture_cluster"
            app:pocketVariant="ghost" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/capture_recipients_container"
        android:layout_width="0dp"
        android:layout_height="78dp"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/camera_controls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/capture_recipient_list"
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:overScrollMode="never"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/history_header"
        android:layout_width="wrap_content"
        android:layout_height="46dp"
        android:background="@drawable/bg_history_pill"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:minWidth="176dp"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/history_count"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_history_count_badge"
            android:gravity="center"
            android:text="@string/history_count_zero"
            android:textColor="@color/pocket_on_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@string/history_title"
            android:textColor="@color/pocket_text_primary"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/history_expand"
            android:textColor="@color/pocket_text_secondary"
            android:textSize="20sp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
